/*Isabela Araujo Almeida Barreto 
Ler dois valores inteiros:
e se forem iguais, mostrar “Números iguais”;
caso contrário, apresentar a diferença do maior pelo menor.
*/
import java.util.Scanner;
public class Exercicio3 {
    public static void main(String[] args) {
        Scanner entrada=new Scanner(System.in);
        System.out.println("digite o numero1:");
        int numero1= entrada.nextInt();
        System.out.println("Digite o numero2:");
        int numero2= entrada.nextInt();

        if(numero1 == numero2){
            System.out.println("numeros iguais");
        }
        else{
            int diferenca;

            if (numero1 > numero2) {
                diferenca = numero1 - numero2;
            } else {
                diferenca = numero2 - numero1;
            }

            System.out.println("Diferença: " + diferenca);
        }

        


        entrada.close(); 
    }

}